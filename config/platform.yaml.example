# ==============================================================================
# ExpHub external platform configuration example
# Copy to config/platform.yaml and update local paths.
# ==============================================================================

environments:
  phases:
    segment:
      python: "/path/to/segmentclip/bin/python"
      conda: "segmentclip"
    semantic_openclip:
      python: "/path/to/segmentclip/bin/python"
      conda: "segmentclip"
    slam:
      python: "/path/to/droid/bin/python"
      conda: "droid"
    decode:
      python: "/path/to/conda/envs/comfyui/bin/python3"
      conda: "comfyui"
    lora:
      python: "/path/to/conda/envs/videox/bin/python"
      conda: "videox"

repos:
  droid_slam: "/path/to/DROID-SLAM"
  videox_fun: "/path/to/VideoX-Fun"

external_codecs:
  dcvc_fm:
    enabled: false
    required: false
    root: "../DCVC-FM"
    # Optional local executable override, for example:
    # python: "/home/hx/anaconda3/envs/dcvc-fm/bin/python"
    python: ""
    script: ""
    model_path_i: ""
    model_path_p: ""
    q_index: 21
    worker: 1
    cuda: true
    force_intra_period: 9999
    command_template: ""

services:
  comfyui:
    active_profile: "base"
    profiles:
      base:
        workflow_json: "/path/to/ExpHub/config/workflows/wan2_2_5b_inp_base.json"
        lora:
          enabled: false
        nodes:
          ksampler: "3"
          positive_prompt: "6"
          negative_prompt: "7"
          vae_decode: "8"
          create_video: "57"
          save_video: "58"
          start_image: "70"
          video_spec: "73"
          end_image: "74"
          save_image: "75"
      lora_gdut:
        workflow_json: "/path/to/ExpHub/config/workflows/wan2_2_5b_inp_lora.json"
        lora:
          enabled: true
          name: "wan22_fun_5b_inp_gdut.safetensors"
          strength_model: 1.0
          strength_clip: 1.0
        nodes:
          ksampler: "11"
          positive_prompt: "16"
          negative_prompt: "12"
          vae_decode: "6"
          create_video: "7"
          save_video: "8"
          start_image: "4"
          video_spec: "9"
          end_image: "5"
          save_image: "10"
          lora_loader: "15"
      lora_ncd:
        workflow_json: "/path/to/ExpHub/config/workflows/wan2_2_5b_inp_lora.json"
        lora:
          enabled: true
          name: "wan22_fun_5b_inp_ncd.safetensors"
          strength_model: 1.0
          strength_clip: 1.0
        nodes:
          ksampler: "11"
          positive_prompt: "16"
          negative_prompt: "12"
          vae_decode: "6"
          create_video: "7"
          save_video: "8"
          start_image: "4"
          video_spec: "9"
          end_image: "5"
          save_image: "10"
          lora_loader: "15"
      lora_tum:
        workflow_json: "/path/to/ExpHub/config/workflows/wan2_2_5b_inp_lora.json"
        lora:
          enabled: true
          name: "wan22_fun_5b_inp_tum.safetensors"
          strength_model: 1.0
          strength_clip: 1.0
        nodes:
          ksampler: "11"
          positive_prompt: "16"
          negative_prompt: "12"
          vae_decode: "6"
          create_video: "7"
          save_video: "8"
          start_image: "4"
          video_spec: "9"
          end_image: "5"
          save_image: "10"
          lora_loader: "15"
    timeout_sec: 1800
    poll_interval_sec: 2.0
    parallel: true
    schedule: "longest_first"
    instances:
      - name: "gpu0"
        base_url: "http://127.0.0.1:8188"
        output_root: "/path/to/ComfyUI/output/gpu0"
      - name: "gpu1"
        base_url: "http://127.0.0.1:8189"
        output_root: "/path/to/ComfyUI/output/gpu1"
      - name: "gpu2"
        base_url: "http://127.0.0.1:8190"
        output_root: "/path/to/ComfyUI/output/gpu2"
    # Single-instance fallback: omit instances above and configure:
    # base_url: "http://127.0.0.1:8188"
    # output_root: "/path/to/ComfyUI/output"
    # parallel: false

models:
  qwen2_vl:
    path: "/path/to/Qwen2-VL-7B-Instruct"

  droid:
    path: "/path/to/DROID-SLAM/droid.pth"
