{
  "schema": "prompt_manifest_v3",
  "prompt_strategy": "four_part_blip2_semantic_v1",
  "semantic_backend": {
    "name": "blip2",
    "default_model": "Salesforce/blip2-opt-2.7b",
    "sample_policy": "start_mid_end"
  },
  "positive_parts": [
